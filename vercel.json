{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "installCommand": "npm install --production",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "same-origin" },
        { "key": "X-Powered-By", "value": "InboxPilot" }
      ]
    }
  ],
  "env": {
    "RESEND_API_KEY": "@inboxpilot-resend-api-key",
    "STRIPE_WEBHOOK_SECRET": "@inboxpilot-stripe-webhook-secret",
    "ENCRYPTION_KEY": "@inboxpilot-encryption-key"
  }
}
